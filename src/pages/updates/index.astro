---
import MainLayout from "../../layouts/MainLayout.astro";
import updates from "../../data/updates.json";

const allUpdates = [...updates].sort((a, b) => new Date(b.date).valueOf() - new Date(a.date).valueOf());

const formatDate = (value: string | Date) =>
  new Date(value).toLocaleDateString("en-US", {
    year: "numeric",
    month: "short",
    day: "numeric"
  });
---

<MainLayout title="Updates | Amit Kiran Rege" description="All updates, milestones, talks, and release notes." pageClass="blog-page">
  <section class="section shell reveal">
    <div class="section-head">
      <h1>All Updates</h1>
      <p>Complete list of talks, milestones, submissions, and releases.</p>
    </div>

    <div class="stack">
      {
        allUpdates.map((item) => (
          <article class="card glass">
            <p class="meta">{formatDate(item.date)}</p>
            <h2>{item.title}</h2>
            <p>{item.detail}</p>
            {item.link && <a class="text-link" href={item.link} target="_blank" rel="noreferrer">Read more</a>}
          </article>
        ))
      }
    </div>
  </section>
</MainLayout>
